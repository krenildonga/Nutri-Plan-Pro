{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "trailingSlash": false,
    "functions": {
        "api/**/*.js": {
            "includeFiles": "../backend/**"
        }
    },
    "rewrites": [
        { "source": "/api/ping", "destination": "/api/ping.js" },
        { "source": "/api/:path*", "destination": "/api/index.js" },
        { "source": "/((?!api/).*)", "destination": "/index.html" }
    ]
}
