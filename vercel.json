{
    "version": 2,
    "buildCommand": "npm run build --workspace=frontend",
    "outputDirectory": "frontend/dist",
    "functions": {
        "api/server.js": {
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/server.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}